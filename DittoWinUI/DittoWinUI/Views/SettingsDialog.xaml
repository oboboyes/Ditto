<Page
    x:Class="DittoWinUI.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DittoWinUI.Views"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="Settings">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="28" FontWeight="Bold" Margin="24,16,24,16"/>

        <SplitView Grid.Row="1" x:Name="SettingsSplitView" 
            DisplayMode="Inline"
            OpenPaneLength="280">
            <SplitView.Pane>
                <ListView x:Name="SettingsNavList" SelectionChanged="SettingsNavList_SelectionChanged">
                    <ListViewItem Content="General" Tag="General" IsSelected="True"/>
                    <ListViewItem Content="Hotkeys" Tag="Hotkeys"/>
                    <ListViewItem Content="Appearance" Tag="Appearance"/>
                    <ListViewItem Content="Storage" Tag="Storage"/>
                    <ListViewItem Content="About" Tag="About"/>
                </ListView>
            </SplitView.Pane>

            <ScrollViewer>
                <StackPanel Margin="24,0,24,24">

                    <StackPanel x:Name="GeneralSettings">
                        <TextBlock Text="General Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <ToggleSwitch x:Name="StartWithWindowsToggle" 
                            Header="Start with Windows"
                            Description="Launch Ditto when Windows starts"/>

                        <ToggleSwitch x:Name="MinimizeToTrayToggle"
                            Header="Minimize to tray"
                            Description="Minimize to system tray instead of taskbar"
                            Margin="0,16,0,0"/>

                        <ToggleSwitch x:Name="ShowNotificationsToggle"
                            Header="Show notifications"
                            Description="Show notifications for clipboard captures"
                            Margin="0,16,0,0"/>

                        <ToggleSwitch x:Name="AutoStartMonitorToggle"
                            Header="Auto-start clipboard monitor"
                            Description="Automatically start monitoring clipboard when launched"
                            Margin="0,16,0,0"/>

                        <ToggleSwitch x:Name="ConfirmDeleteToggle"
                            Header="Confirm before delete"
                            Description="Ask for confirmation before deleting clips"
                            Margin="0,16,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="HotkeysSettings" Visibility="Collapsed">
                        <TextBlock Text="Hotkeys" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Quick Paste" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="QuickPasteHotkeyBox" 
                                IsReadOnly="True" Text="Ctrl+`"/>
                            <Button Grid.Column="1" Content="Record" Margin="8,0,0,0" 
                                Click="RecordHotkey_Click"/>
                        </Grid>

                        <TextBlock Text="Global Paste" FontWeight="SemiBold" Margin="0,24,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="GlobalPasteHotkeyBox" 
                                IsReadOnly="True" Text="Ctrl+Shift+`"/>
                            <Button Grid.Column="1" Content="Record" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="AppearanceSettings" Visibility="Collapsed">
                        <TextBlock Text="Appearance" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ThemeComboBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="System Default" IsSelected="True"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Dark"/>
                        </ComboBox>

                        <ToggleSwitch x:Name="MicaBackdropToggle"
                            Header="Mica backdrop"
                            Description="Use Mica material effect (Windows 11 only)"
                            Margin="0,24,0,0"/>

                        <ToggleSwitch x:Name="RoundedCornersToggle"
                            Header="Rounded corners"
                            Description="Use rounded window corners"
                            Margin="0,16,0,0"/>

                        <ToggleSwitch x:Name="ShowItemPreviewToggle"
                            Header="Show item preview"
                            Description="Show preview when hovering over items"
                            Margin="0,16,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="StorageSettings" Visibility="Collapsed">
                        <TextBlock Text="Storage" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <TextBlock Text="Maximum clips to keep" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="MaxClipsSlider" 
                                Minimum="100" Maximum="10000" Value="1000" Width="250"/>
                            <TextBlock Grid.Column="1" 
                                Text="{Binding Value, ElementName=MaxClipsSlider}" 
                                VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Maximum storage size (MB)" FontWeight="SemiBold" Margin="0,24,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="MaxStorageSlider"
                                Minimum="100" Maximum="5000" Value="500" Width="250"/>
                            <TextBlock Grid.Column="1"
                                Text="{Binding Value, ElementName=MaxStorageSlider}"
                                VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Database Location" FontWeight="SemiBold" Margin="0,24,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="DatabasePathBox" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"/>
                        </Grid>

                        <Button Content="Purge Old Clips" Margin="0,24,0,0" HorizontalAlignment="Left"/>
                        <TextBlock Text="Remove clips beyond the maximum limit" 
                            FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="AboutSettings" Visibility="Collapsed">
                        <TextBlock Text="About" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal">
                            <SymbolIcon Symbol="Clipboard" FontSize="48"/>
                            <StackPanel Margin="16,0,0,0">
                                <TextBlock Text="Ditto WinUI 3" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Version 1.0.0" FontSize="14" 
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="A modern clipboard manager for Windows" 
                            Margin="0,16,0,0" TextWrapping="Wrap"/>

                        <TextBlock Margin="0,24,0,0">
                            <Run Text="Built with WinUI 3 and C++/WinRT"/><LineBreak/>
                            <Run Text="Designed for Windows 10 and Windows 11"/>
                        </TextBlock>

                        <Button Content="Check for Updates" Margin="0,24,0,0" HorizontalAlignment="Left"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </SplitView>
    </Grid>
</Page>
