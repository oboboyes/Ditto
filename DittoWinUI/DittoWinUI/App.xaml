<Application
    x:Class="DittoWinUI.App"
    x:Name="App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DittoWinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ThemeResources xmlns="using:Microsoft.UI.Xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush x:Key="TextBrush" Color="{ThemeResource SystemAccentColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
